@model StreamVaultAdmin.Models.Content

@{
    ViewData["Title"] = "Delete Content";
}

<h2>Delete Content</h2>

<div class="alert alert-warning">
    <h4>Are you sure you want to delete this content?</h4>
    <p>This action cannot be undone.</p>
</div>

<div class="card mb-4">
    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">
                Title
            </dt>

            <dd class="col-sm-9">
                @Model.Title
            </dd>

            <dt class="col-sm-3">
                Type
            </dt>

            <dd class="col-sm-9">
                @Model.ContentType
            </dd>

            <dt class="col-sm-3">
                Genre
            </dt>

            <dd class="col-sm-9">
                @Model.Genre
            </dd>

            <dt class="col-sm-3">
                Release Date
            </dt>

            <dd class="col-sm-9">
                @Model.ReleaseDate.ToString("dd MMM yyyy")
            </dd>

            <dt class="col-sm-3">
                Description
            </dt>

            <dd class="col-sm-9">
                @Model.Description
            </dd>

        </dl>

    </div>
</div>

<form asp-action="Delete" method="post">

    <input asp-for="Id" type="hidden" />

    @Html.AntiForgeryToken()

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>