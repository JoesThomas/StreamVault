@model StreamVaultAdmin.ViewModels.ContentViewModel

<!--
    Partial view containing the shared form used by both the
    Create and Edit pages. The form captures common content
    properties as well as fields specific to each content type.
-->

<div class="mb-3">

    <label asp-for="Title"></label>

    <input asp-for="Title" class="form-control" />

    <span asp-validation-for="Title" class="text-danger"></span>

</div>
<div class="mb-3">
    <label asp-for="Description"></label>
    <textarea asp-for="Description" class="form-control"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="ReleaseDate"></label>
    <input asp-for="ReleaseDate" class="form-control" type="date" />
    <span asp-validation-for="ReleaseDate" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="Genre"></label>
    <input asp-for="Genre" class="form-control" />
    <span asp-validation-for="Genre" class="text-danger"></span>
</div>

<div class="mb-3">
    <label asp-for="AgeRating"></label>
    <input asp-for="AgeRating" class="form-control" />
    <span asp-validation-for="AgeRating" class="text-danger"></span>
</div>
<div class="mb-3">

    <label asp-for="SelectedType"></label>

    <select asp-for="SelectedType"
            class="form-select"
            asp-items="Html.GetEnumSelectList<ContentType>()">
        <option value="">All Content Types</option>
    </select>

</div>
<div id="movieFields">

    <h4>Movie</h4>

    <div class="mb-3">

        <label asp-for="Director"></label>

        <input asp-for="Director"
               class="form-control" />

    </div>

    <div class="mb-3">

        <label asp-for="DurationMinutes"></label>

        <input asp-for="DurationMinutes"
               class="form-control" />

    </div>

</div>
<div id="seriesFields">

    <h4>Series</h4>

    <input asp-for="NumberOfSeasons"
           class="form-control mb-2" />

    <input asp-for="TotalEpisodes"
           class="form-control" />

</div>
<div id="audiobookFields">

    <input asp-for="Author"
           class="form-control mb-2" />

    <input asp-for="Narrator"
           class="form-control mb-2" />

    <input asp-for="DurationMinutes"
           class="form-control" />

</div>
<div id="musicFields">

    <input asp-for="Artist"
           class="form-control mb-2" />

    <input asp-for="TrackCount"
           class="form-control mb-2" />

    <input asp-for="RecordLabel"
           class="form-control" />

</div>
<div class="mt-4">

    <button class="btn btn-primary">

        Save

    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancel

    </a>

</div>
<script>
    // Get references to the content type dropdown and each
    // section containing type-specific input fields.
    const typeSelect = document.getElementById("contentType");

    const movie = document.getElementById("movieFields");
    const series = document.getElementById("seriesFields");
    const audio = document.getElementById("audiobookFields");
    const music = document.getElementById("musicFields");

    // Displays only the fields that correspond to the
    // currently selected content type.
    function refresh() {

        movie.style.display = "none";
        series.style.display = "none";
        audio.style.display = "none";
        music.style.display = "none";

        // Show the appropriate section.
        switch (typeSelect.value) {
            case "Movie":
                movie.style.display = "block";
                break;

            case "Series":
                series.style.display = "block";
                break;

            case "Audiobook":
                audio.style.display = "block";
                break;

            case "MusicAlbum":
                music.style.display = "block";
                break;
        }
    }

    typeSelect.addEventListener("change", refresh);
    // Initialise the correct fields when the page loads.
    refresh();
</script>